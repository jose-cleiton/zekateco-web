MYSQL_ROOT_PASSWORD=changeme-root
MYSQL_DATABASE=zekateco
MYSQL_USER=zekateco
MYSQL_PASSWORD=changeme-app

# --- Modo read-only + mirror (Soltech → zekateco-web) -----------------------
# READ_ONLY=1 → rejeita mutações /api com 501 e não enfileira comandos pro REP.
# Comandos ao REP continuam via Soltech. Deixe 0 em dev local.
READ_ONLY=1

# Secret compartilhado com o Soltech (ZEKATECO_MIRROR_SECRET). Requests
# recebidas em /__mirror/iclock/* são validadas contra esse valor.
# Gere: openssl rand -hex 32
MIRROR_SECRET=

# --- Webdriver mode via API do Soltech --------------------------------------
# Quando setado, endpoints de comando (/api/sync-users, /api/devices/:sn/reboot,
# etc.) chamam POST /rep/zkteco/send-command/:sn do Soltech em vez de
# enfileirar na nossa fila local. Assim conseguimos comandar qualquer REP
# cadastrado no Soltech, não só os que apontam pra 2.25.208.124.
# Requer client Keycloak criado pelo time do Soltech.
SOLTECH_API_URL=https://api.ultraponto.ultrasistech.com.br
KEYCLOAK_URL=http://72.62.173.226:9092
KEYCLOAK_REALM=Ultraponto
KEYCLOAK_CLIENT_ID=zekateco-web
KEYCLOAK_CLIENT_SECRET=
