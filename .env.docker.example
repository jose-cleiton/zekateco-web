MYSQL_ROOT_PASSWORD=changeme-root
MYSQL_DATABASE=zekateco
MYSQL_USER=zekateco
MYSQL_PASSWORD=changeme-app

# --- Modo read-only + mirror (Soltech → zekateco-web) -----------------------
# READ_ONLY=1 → rejeita mutações /api com 501 e não enfileira comandos pro REP.
# Comandos ao REP continuam via Soltech. Deixe 0 em dev local.
READ_ONLY=1

# Secret compartilhado com o Soltech (ZEKATECO_MIRROR_SECRET). Requests
# recebidas em /__mirror/iclock/* são validadas contra esse valor.
# Gere: openssl rand -hex 32
MIRROR_SECRET=
